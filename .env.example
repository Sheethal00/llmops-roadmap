# Anthropic API — required for all phases that call the primary LLM
ANTHROPIC_API_KEY=

# Hugging Face — required for Phase 3 (push adapter to Hub)
HF_TOKEN=

# Weights & Biases — required for Phase 3 experiment tracking (or use MLflow)
WANDB_API_KEY=
WANDB_PROJECT=llmops-roadmap

# Langfuse — required for Phase 6 observability (self-hosted or cloud)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Vector DB — Qdrant (default). Override if using pgvector.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Phase 4 — Ollama base URL (default local)
OLLAMA_BASE_URL=http://localhost:11434
